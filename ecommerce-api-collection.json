{
  "info": {
    "_postman_id": "nazir-ecommerce-microservices",
    "name": "Nazir E-Commerce Microservices",
    "description": "Complete API collection for all 6 microservices.\n\n**Setup:**\n1. Start all services (see README)\n2. Set `baseUrl` variable to `http://localhost:8080` (via gateway) or service-specific port\n3. Run `POST Auth / Register` then `POST Auth / Login` — token auto-saved\n4. All protected endpoints use the saved `{{accessToken}}`\n\n**Services:**\n- API Gateway: 8080\n- User Service: 8081\n- Order Service: 8082\n- Payment Service: 8083\n- Notification Service: 8084\n- Product Service: 8085",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "userDirect",   "value": "http://localhost:8081", "type": "string" },
    { "key": "productDirect","value": "http://localhost:8085", "type": "string" },
    { "key": "orderDirect",  "value": "http://localhost:8082", "type": "string" },
    { "key": "paymentDirect","value": "http://localhost:8083", "type": "string" },
    { "key": "notifDirect",  "value": "http://localhost:8084", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" },
    { "key": "userEmail",    "value": "", "type": "string" },
    { "key": "productId",    "value": "", "type": "string" },
    { "key": "orderId",      "value": "", "type": "string" },
    { "key": "paymentId",    "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('userId', data.id);",
            "  pm.collectionVariables.set('userEmail', data.email);",
            "  pm.test('User registered', () => pm.expect(pm.response.code).to.equal(201));",
            "  pm.test('ID returned', () => pm.expect(data.id).to.not.be.empty);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"nazir\",\n  \"email\": \"nazir@example.com\",\n  \"password\": \"Test@12345\",\n  \"firstName\": \"Nazir\",\n  \"lastName\": \"Khan\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('accessToken',  data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
            "  pm.collectionVariables.set('userId',       data.userId);",
            "  pm.test('Login success',    () => pm.expect(pm.response.code).to.equal(200));",
            "  pm.test('Token returned',   () => pm.expect(data.accessToken).to.not.be.empty);",
            "  console.log('Token saved:', data.accessToken.substring(0,20) + '...');",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nazir@example.com\",\n  \"password\": \"Test@12345\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('accessToken', data.accessToken);",
            "  pm.collectionVariables.set('userId', data.userId);",
            "  pm.test('Admin login success', () => pm.expect(pm.response.code).to.equal(200));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"Admin@12345\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "Authorization",  "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nazir@example.com\"\n}" }
          }
        }
      ]
    },

    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Get My Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Profile returned', () => pm.expect(pm.response.code).to.equal(200));",
            "pm.test('Email matches', () => {",
            "  const email = pm.response.json().data?.email;",
            "  pm.expect(email).to.not.be.empty;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"] },
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Nazir\",\n  \"lastName\":  \"Updated\",\n  \"phone\":     \"+91-9876543210\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/users/me/password", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me","password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Test@12345\",\n  \"newPassword\":     \"NewPass@12345\"\n}" }
          }
        },
        {
          "name": "Get User by ID (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","users","{{userId}}"] }
          }
        },
        {
          "name": "List All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=0&size=10&sort=createdAt,desc",
              "host": ["{{baseUrl}}"], "path": ["api","v1","admin","users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            }
          }
        },
        {
          "name": "Suspend User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/suspend", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","users","{{userId}}","suspend"] },
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Policy violation\"\n}" }
          }
        }
      ]
    },

    {
      "name": "📦 Products",
      "item": [
        {
          "name": "List Products (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?page=0&size=12&sort=createdAt,desc",
              "host": ["{{baseUrl}}"], "path": ["api","v1","products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "12" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?search=laptop&category=electronics&minPrice=500&maxPrice=2000&page=0&size=10",
              "host": ["{{baseUrl}}"], "path": ["api","v1","products"],
              "query": [
                { "key": "search",   "value": "laptop" },
                { "key": "category", "value": "electronics" },
                { "key": "minPrice", "value": "500" },
                { "key": "maxPrice", "value": "2000" },
                { "key": "page",     "value": "0" },
                { "key": "size",     "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID (Cached)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Product returned', () => pm.expect(pm.response.code).to.equal(200));",
            "pm.test('Has ID', () => pm.expect(pm.response.json().data?.id).to.not.be.empty);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}"] }
          }
        },
        {
          "name": "Get Product Stock (Live)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}/stock", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}","stock"] }
          }
        },
        {
          "name": "Create Product",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const id = pm.response.json().data?.id;",
            "  pm.collectionVariables.set('productId', id);",
            "  pm.test('Product created', () => pm.expect(pm.response.code).to.equal(201));",
            "  pm.test('ID saved', () => pm.expect(id).to.not.be.empty);",
            "  console.log('productId saved:', id);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api","v1","products"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\":          \"MacBook Pro M3 14\",\n  \"description\":   \"Apple M3 Pro chip, 18GB RAM, 512GB SSD\",\n  \"brand\":         \"Apple\",\n  \"category\":      \"laptops\",\n  \"price\":         1999.00,\n  \"stockQuantity\": 50,\n  \"attributes\": {\n    \"ram\":     \"18GB\",\n    \"chip\":    \"M3 Pro\",\n    \"storage\": \"512GB\",\n    \"display\": \"14-inch Liquid Retina XDR\"\n  }\n}" }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"price\":       1899.00,\n  \"description\": \"Updated: Apple M3 Pro chip, now with 512GB SSD\"\n}" }
          }
        },
        {
          "name": "Reserve Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}/reserve-stock", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}","reserve-stock"] },
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2,\n  \"orderId\":  \"test-order-001\"\n}" }
          }
        },
        {
          "name": "Release Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}/release-stock", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}","release-stock"] },
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2,\n  \"orderId\":  \"test-order-001\"\n}" }
          }
        },
        {
          "name": "Confirm Stock Deduction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}/confirm-stock", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}","confirm-stock"] },
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2,\n  \"orderId\":  \"test-order-001\"\n}" }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}"] }
          }
        }
      ]
    },

    {
      "name": "🛒 Orders",
      "item": [
        {
          "name": "Place Order",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const data = pm.response.json().data;",
            "  pm.collectionVariables.set('orderId', data.id);",
            "  pm.test('Order placed',        () => pm.expect(pm.response.code).to.equal(201));",
            "  pm.test('Status is PENDING',   () => pm.expect(data.status).to.equal('PENDING'));",
            "  pm.test('Order number exists', () => pm.expect(data.orderNumber).to.match(/^ORD-/));",
            "  console.log('orderId saved:', data.id);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Auth-User-Id",    "value": "{{userId}}" },
              { "key": "X-Auth-User-Email", "value": "nazir@example.com" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders", "host": ["{{baseUrl}}"], "path": ["api","v1","orders"] },
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\":  2\n    }\n  ],\n  \"shippingAddress\": {\n    \"streetAddress\": \"123 MG Road\",\n    \"city\":          \"Bengaluru\",\n    \"state\":         \"Karnataka\",\n    \"postalCode\":    \"560001\",\n    \"country\":       \"IN\"\n  },\n  \"notes\": \"Please leave at door\"\n}" }
          }
        },
        {
          "name": "Get Order by ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Order returned', () => pm.expect(pm.response.code).to.equal(200));",
            "const status = pm.response.json().data?.status;",
            "console.log('Current order status:', status);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{accessToken}}" },
              { "key": "X-Auth-User-Id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","orders","{{orderId}}"] }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{accessToken}}" },
              { "key": "X-Auth-User-Id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/my-orders", "host": ["{{baseUrl}}"], "path": ["api","v1","orders","my-orders"] }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "X-Auth-User-Id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","v1","orders","{{orderId}}","cancel"] },
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Changed my mind\"\n}" }
          }
