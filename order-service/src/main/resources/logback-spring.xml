<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Import Spring Boot defaults -->
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Service name from Spring properties — used in every log line -->
  <springProperty name="SERVICE_NAME" source="spring.application.name" defaultValue="unknown-service"/>

  <!-- ── Local development: colored console output ──────────────────────── -->
  <springProfile name="!docker">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <!--
          %clr(...)        → colorize the enclosed text based on log level
          [%X{traceId:-}]  → Micrometer inserts traceId into MDC automatically
          [%X{spanId:-}]   → same for spanId
        -->
        <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr([${SERVICE_NAME}]){cyan} %clr([%X{traceId:-},%X{spanId:-}]){blue} %clr(%-40.40logger{39}){magenta} : %m%n%wEx</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <!-- ── Docker/production: JSON output (for ELK ingestion) ────────────── -->
  <springProfile name="docker">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <!--
          LogstashEncoder outputs structured JSON automatically.
          MDC fields (traceId, spanId) are included automatically.
          Add custom fields present on every log line:
        -->
        <customFields>{"service":"${SERVICE_NAME}","environment":"docker"}</customFields>
        <fieldNames>
          <timestamp>@timestamp</timestamp>
          <message>message</message>
          <logger>logger</logger>
          <thread>thread</thread>
          <level>level</level>
        </fieldNames>
        <!-- Include MDC (Mapped Diagnostic Context) — traceId/spanId from Micrometer -->
        <includeMdcKeyName>traceId</includeMdcKeyName>
        <includeMdcKeyName>spanId</includeMdcKeyName>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <!-- Reduce noise from framework packages in production -->
    <logger name="org.springframework.cloud.netflix.eureka" level="WARN"/>
    <logger name="com.netflix.discovery" level="WARN"/>
    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>

    <!-- Keep application code at DEBUG for detailed traces -->
    <logger name="com.nazir.ecommerce" level="DEBUG"/>
  </springProfile>

</configuration>
