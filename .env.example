# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values
# NEVER commit the real .env to Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# Must be >= 256 bits (32+ chars) for HS256 JWT signing
JWT_SECRET=NazirEcommerceSecretKeyMustBeAtLeast256BitsLongForHS256Algorithm!

CONFIG_SERVER_USERNAME=configuser
CONFIG_SERVER_PASSWORD=configpassword

EUREKA_USERNAME=eurekauser
EUREKA_PASSWORD=eurekapassword

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=nazirredis
